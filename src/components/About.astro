---
const hosts = [
  {
    name: 'Jacob Adams',
    role: 'Co-Host',
    image: '/jacob.jpg',
    credentials: [
      'Gallup Certified CliftonStrengths Coach',
      '20+ Years in Tech as PM, TPM & Software Engineer',
      'Microsoft — Copilot Security, OneNote, PowerPoint, Phone Link, Azure',
      '5x AI Startup Founder & TechCrunch Disrupt Battlefield Finalist',
      'MIT Certified in AI Products & Services',
      'Dale Carnegie Graduate & Award Recipient',
    ],
    bio: 'Jacob has spent 20+ years building products and leading teams across Microsoft, Azure, and five AI startups — shipping 10+ products serving millions of users. As a Gallup Certified CliftonStrengths Coach, he\'s coached over 2,000 people through 1:1 sessions and team workshops of up to 100 participants, helping people discover their unique talents and align them with their purpose. He brings a rare blend of enterprise leadership, startup grit, and a deep coaching mindset to every conversation.',
    linkedin: 'https://www.linkedin.com/in/jacoblewisadams/',
  },
  {
    name: 'Diana Urbina',
    role: 'Co-Host',
    image: '/diana.jpg',
    credentials: [
      'Executive & Team Coach',
      'Culture Consultant & Strategist',
      'Founder of Sharro Solutions',
      'Nearly 30 Years Corporate Leadership',
      'Certified in Multiple Coaching Modalities',
    ],
    bio: 'Diana is an Executive & Team Coach and Culture Consultant who has spent nearly three decades inside the corporate engine — leading, building, and navigating. She specializes in identity alignment, leadership transformation, and building coherent cultures where leaders and teams can thrive authentically.',
    linkedin: 'https://www.linkedin.com/in/dianaurbina/',
  },
];
---

<section class="about section" id="about">
  <div class="container">
    <div class="about-header fade-in">
      <span class="section-label">About the Podcast</span>
      <h2 class="section-title">Two Coaches. Real Stories. Your Purpose.</h2>
      <p class="section-subtitle">
        Purpose by Design is a podcast where real people share how they discovered 
        their purpose and used their unique talents to build something meaningful. 
        Each episode breaks down the moments, decisions, and struggles that shaped 
        their journey—what worked, what didn't, and what they're pursuing now. 
        It's raw, honest, and built to help you uncover your own.
      </p>
      <hr class="divider" />
    </div>

    <div class="hosts-grid">
      {hosts.map((host, i) => (
        <article class="host-card fade-in" style={`transition-delay: ${i * 150}ms`}>
          <div class="host-image-wrapper">
            <img src={host.image} alt={host.name} width="200" height="200" loading="lazy" />
          </div>
          <div class="host-info">
            <h3 class="host-name">{host.name}</h3>
            <span class="host-role">{host.role}</span>
            <ul class="host-credentials">
              {host.credentials.map((cred) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {cred}
                </li>
              ))}
            </ul>
            <p class="host-bio">{host.bio}</p>
            <a href={host.linkedin} target="_blank" rel="noopener noreferrer" class="host-linkedin" aria-label={`${host.name} on LinkedIn`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .about-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-4xl);
  }

  .hosts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .host-card {
    background: var(--color-surface);
    border: 1px solid rgba(201, 168, 76, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .host-card:hover {
    border-color: rgba(201, 168, 76, 0.3);
    box-shadow: var(--shadow-gold);
  }

  .host-image-wrapper {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-gold);
    padding: 3px;
    margin-bottom: var(--space-xl);
    background: linear-gradient(135deg, rgba(201, 168, 76, 0.2), transparent);
  }

  .host-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .host-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .host-role {
    font-size: var(--text-sm);
    color: var(--color-gold);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .host-credentials {
    width: 100%;
    text-align: left;
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .host-credentials li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .host-credentials svg {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .host-bio {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .host-linkedin {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-gold);
    transition: color var(--transition-fast);
  }

  .host-linkedin:hover {
    color: var(--color-gold-light);
  }

  @media (max-width: 768px) {
    .hosts-grid {
      grid-template-columns: 1fr;
    }

    .host-card {
      padding: var(--space-xl);
    }
  }
</style>
