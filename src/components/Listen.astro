---

<section class="listen section" id="listen">
  <div class="container">
    <div class="listen-header fade-in">
      <span class="section-label">Listen</span>
      <h2 class="section-title">Available On Your Favorite Platform</h2>
      <p class="section-subtitle" style="text-align: center;">
        Subscribe wherever you listen to podcasts. New episodes dropping soon.
      </p>
      <hr class="divider" />
    </div>

    <div class="platforms-grid fade-in">
      {platforms.map((platform) => (
        <a
          href={platform.href}
          class="platform-card"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Listen on ${platform.name}`}
        >
          <span class="platform-icon" set:html={platform.icon} />
          <span class="platform-name">{platform.name}</span>
          <span class="platform-soon">Coming Soon</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .listen-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-3xl);
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    max-width: 800px;
    margin: 0 auto;
  }

  .platform-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-surface);
    border: 1px solid rgba(201, 168, 76, 0.1);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    text-align: center;
  }

  .platform-card:hover {
    border-color: rgba(201, 168, 76, 0.3);
    transform: translateY(-4px);
    box-shadow: var(--shadow-gold);
  }

  .platform-icon {
    color: var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(201, 168, 76, 0.1);
    transition: background var(--transition-base);
  }

  .platform-card:hover .platform-icon {
    background: rgba(201, 168, 76, 0.2);
  }

  .platform-name {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }

  .platform-soon {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .platforms-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .platforms-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
