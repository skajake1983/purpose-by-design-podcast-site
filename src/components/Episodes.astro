---
---

<section class="episodes section" id="episodes">
  <div class="container">
    <div class="episodes-header fade-in">
      <span class="section-label">Episodes</span>
      <h2 class="section-title">Stories of Purpose</h2>
      <hr class="divider" />
    </div>

    <div class="episodes-coming-soon fade-in">
      <div class="coming-soon-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
          <line x1="12" y1="19" x2="12" y2="23"></line>
          <line x1="8" y1="23" x2="16" y2="23"></line>
        </svg>
      </div>
      <h3 class="coming-soon-title">Coming Soon</h3>
      <p class="coming-soon-text">
        We're preparing incredible conversations with inspiring people who have 
        discovered their purpose, leveraged their strengths, and are making an 
        impact. Stay tuned for our launch!
      </p>
      <div class="coming-soon-features">
        <div class="feature-item">
          <span class="feature-icon">🎯</span>
          <span>Purpose Discovery Stories</span>
        </div>
        <div class="feature-item">
          <span class="feature-icon">💪</span>
          <span>Strengths-Based Insights</span>
        </div>
        <div class="feature-item">
          <span class="feature-icon">🗺️</span>
          <span>Actionable Steps & Strategies</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .episodes-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-3xl);
  }

  .episodes-coming-soon {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    background: var(--color-surface);
    border: 1px solid rgba(201, 168, 76, 0.15);
    border-radius: var(--radius-lg);
  }

  .coming-soon-icon {
    color: var(--color-gold);
    margin-bottom: var(--space-xl);
    opacity: 0.8;
  }

  .coming-soon-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: var(--space-lg);
    letter-spacing: 0.05em;
  }

  .coming-soon-text {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-2xl);
  }

  .coming-soon-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .feature-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .feature-icon {
    font-size: 1.2rem;
  }
</style>
