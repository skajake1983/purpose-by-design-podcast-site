---

<section class="episodes section" id="episodes">
  <div class="container">
    <div class="episodes-header fade-in">
      <span class="section-label">Episodes</span>
      <h2 class="section-title">Stories of Purpose</h2>
      <hr class="divider" />
    </div>

    <div class="episodes-player fade-in">
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/show/6TGpaHbkj4jJHRFSkfuIrb?utm_source=generator&theme=0"
        width="100%"
        height="352"
        frameborder="0"
        allowfullscreen
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"
        title="Purpose by Design Podcast on Spotify"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .episodes-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-3xl);
  }

  .episodes-player {
    max-width: 800px;
    margin: 0 auto;
  }
</style>
